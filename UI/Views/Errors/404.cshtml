@{
    Layout = null;
    ViewData["Title"] = "Page Not Found";
}
<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] — @appSettings.Value.AppName</title>

    <link rel="shortcut icon" href="~/images/favicon.ico" />
    <style>
        body {
            margin: 0;
            background-color: #000;
        }

        .error-bg {
            background-size: cover;
            background-position: center;
            height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            color: white;
            padding: 0 20px;
            position: relative;
        }

        /* 🔹 Move the text area toward the top */
        .error-container {
            margin-top: 12vh; /* adjust 10–15vh for more/less height */
            max-width: 700px;
        }

            .error-container h1 {
                font-size: 60px;
                font-weight: 700;
                margin-bottom: 10px;
                letter-spacing: 1px;
            }

            .error-container p {
                font-size: 20px;
                line-height: 1.6;
                font-weight: 300;
                margin-bottom: 25px;
            }

        .error-btn {
            display: inline-block;
            padding: 12px 35px;
            font-size: 16px;
            font-weight: 500;
            color: #fff;
            background-color: transparent;
            border: 2px solid #fff;
            border-radius: 8px;
            text-decoration: none;
            transition: all 0.3s ease;
        }

            .error-btn:hover {
                background-color: #fff;
                color: #000;
            }

        /* Subtle overlay for readability */
        .error-bg::before {
            content: "";
            position: absolute;
            inset: 0;
            background: rgba(0, 0, 0, 0.35);
            z-index: 0;
        }

        .error-container {
            position: relative;
            z-index: 1;
        }
    </style>
</head>

<body>
    <div class="error-bg" style="background-image:url('@Url.Content("~/Images/404Error-background.jpg")');">
        <div class="error-container">
            <h1>Page Not Found</h1>
            <p>
                Sorry, we can't seem to find the page you're looking for.<br />
                There may be a misspelling in the URL entered,<br />
                or the page you are looking for may no longer exist.
            </p>

            <!-- 🏠 Back to Home button -->
            <a href="@Url.Action("Signin", "Account")" class="error-btn">← Back to Sign In</a>
        </div>
    </div>
</body>
</html>
