@{
    Layout = null;
    ViewData["Title"] = "Something went wrong";
}
<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] — @appSettings.Value.AppName</title>

    <link rel="shortcut icon" href="~/images/favicon.ico" />
    <style>
        body {
            margin: 0;
            background-color: #000;
        }

        .error-bg {
            background-size: cover;
            background-position: center;
            height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            color: white;
            padding: 0 20px;
            position: relative;
        }

        /* 🔹 Text box positioned toward the top */
        .kt-error_container {
            margin-top: 12vh; /* move text higher (10–15vh looks good) */
            max-width: 700px;
        }

            .kt-error_container h1 {
                font-size: 60px;
                font-weight: 700;
                margin-bottom: 10px;
                letter-spacing: 1px;
            }

            .kt-error_container p {
                font-size: 20px;
                line-height: 1.6;
                font-weight: 300;
                margin-bottom: 25px;
            }

        .error-btn {
            display: inline-block;
            padding: 12px 35px;
            font-size: 16px;
            font-weight: 500;
            color: #fff;
            background-color: transparent;
            border: 2px solid #fff;
            border-radius: 8px;
            text-decoration: none;
            transition: all 0.3s ease;
        }

            .error-btn:hover {
                background-color: #fff;
                color: #000;
            }

        /* subtle shadow overlay to improve text contrast */
        .error-bg::before {
            content: "";
            position: absolute;
            inset: 0;
            background: rgba(0, 0, 0, 0.35);
            z-index: 0;
        }

        .kt-error_container {
            position: relative;
            z-index: 1;
        }
    </style>
</head>

<body>
    <div class="error-bg" style="background-image:url('@Url.Content("~/Images/500Error-background.jpg")');">
        <div class="kt-error_container">
            <h1>Oops...</h1>
            <p>
                Looks like something went wrong.<br />
                We're working on it.
            </p>

            <!-- 🏠 Back to Home button -->
            <a href="@Url.Action("Signin", "Account")" class="error-btn">← Back to Sign In</a>
        </div>
    </div>
</body>
</html>
