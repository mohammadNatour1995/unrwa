@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Manage Exceptions";
}

<div>
    <!--begin::Toolbar-->
    <div class="toolbar" id="kt_toolbar">
        <div id="kt_toolbar_container" class="container-fluid d-flex flex-stack">

            <div data-kt-swapper="true" data-kt-swapper-mode="prepend" class="page-title d-flex align-items-center me-3 flex-wrap lh-1 mb-5 mb-lg-0" data-kt-swapper-parent="{default: '#kt_content_container', 'lg': '#kt_toolbar_container'}">
                <h1 class="text-gray-900 fw-bold my-1 fs-3">
                    Manage Exceptions
                </h1>

                <span class="h-20px border-gray-200 border-start mx-4"></span>

                <ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7 my-1">
                    <li class="breadcrumb-item text-muted">
                        <a asp-controller="Home" asp-action="Dashboard"
                           class="text-muted text-hover-primary">Home</a>
                    </li>

                    <li class="breadcrumb-item">
                        <span class="bullet bg-gray-300 w-5px h-2px"></span>
                    </li>

                    <li class="breadcrumb-item text-muted">
                        Exceptions
                    </li>

                    <li class="breadcrumb-item">
                        <span class="bullet bg-gray-300 w-5px h-2px"></span>
                    </li>

                    <li class="breadcrumb-item text-gray-900">Manage</li>
                </ul>
            </div>

            <!-- Actions -->
            <div class="d-flex align-items-center py-1">

                <div class="me-4">
                    <button type="button"
                            class="btn btn-sm btn-primary"
                            data-kt-menu-trigger="click"
                            data-kt-menu-placement="bottom-end">
                        <i class="ki-outline ki-exit-up fs-5"></i>Export
                    </button>

                    <div class="menu menu-sub menu-sub-dropdown menu-column menu-rounded menu-gray-600 menu-state-bg-light-primary fw-semibold fs-7 w-200px py-4"
                         data-kt-menu="true">

                        <div class="menu-item px-3">
                            <a href="javascript:void(0)" id="btnCopyToClipboard" class="menu-link px-3">Copy to clipboard</a>
                        </div>

                        <div class="menu-item px-3">
                            <a href="javascript:void(0)" id="btnExportToExcel" class="menu-link px-3">Export as Excel</a>
                        </div>

                        <div class="menu-item px-3">
                            <a href="javascript:void(0)" id="btnExportToCSV" class="menu-link px-3">Export as CSV</a>
                        </div>

                        <div class="menu-item px-3">
                            <a href="javascript:void(0)" id="btnExportToPDF" class="menu-link px-3">Export as PDF</a>
                        </div>

                        <div class="menu-item px-3">
                            <a href="javascript:void(0)" id="btnExportToPrint" class="menu-link px-3">Export as Print</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!--begin::Post-->
    <div class="post d-flex flex-column-fluid" id="kt_post">
        <div id="kt_content_container" class="container-xxl" style="max-width:100%">

            <div class="d-flex flex-column flex-lg-row-fluid gap-7 gap-lg-10">

                <!-- Filter Card -->
                <div class="card">
                    <div class="card-header border-0 pt-2">
                        <div class="card-title">Filter</div>
                    </div>

                    <div class="separator separator-solid"></div>

                    <div class="card-body">

                        <div class="row mb-7">

                            <!-- Message -->
                            <div class="col-md-6">
                                <label class="form-label">Message</label>
                                <input class="form-control"
                                       id="txtMessage"
                                       placeholder="Message">
                            </div>

                            <!-- Request Path -->
                            <div class="col-md-6">
                                <label class="form-label">Request Path</label>
                                <input class="form-control"
                                       id="txtRequestPath"
                                       placeholder="Request Path">
                            </div>

                        </div>

                        <div class="row mb-7">

                            <!-- Function Name -->
                            <div class="col-md-6">
                                <label class="form-label">Function Name</label>
                                <input class="form-control"
                                       id="txtFunctionName"
                                       placeholder="Function Name">
                            </div>

                            <!-- User Id -->
                            <div class="col-md-6">
                                <label class="form-label">User Name </label>
                              
                                <select id="ddlContactUser" class="form-select " data-control="select2" data-placeholder="Please Select" name="ddlContactUser">
                                    <option value="-1">Please Select</option>
                                </select>
                            </div>

                        </div>

                        <div class="d-flex justify-content-end align-items-center mt-5">
                            <input value="Clear"
                                   type="button"
                                   id="btnClear"
                                   class="btn btn-light me-5" />

                            <input type="button"
                                   class="btn btn-primary"
                                   value="Filter"
                                   id="btnFilter">
                        </div>

                    </div>
                </div>

                <!-- Table Card -->
                <div class="card">
                    <div>
                        <div id="divTable" class="table-responsive"></div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>
<!--begin::Modal-->
<div class="modal fade" id="logDetailsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content">

            <!--begin::Modal header-->
            <div class="modal-header">
                <h2 class="fw-bolder">Log Details</h2>

                <div class="btn btn-icon btn-sm btn-active-icon-primary"
                     data-bs-dismiss="modal">
                    <i class="ki-duotone ki-cross fs-1"></i>
                </div>
            </div>
            <!--end::Modal header-->
            <!--begin::Modal body-->
            <div class="modal-body py-5 px-10">

                <form id="form1">

                    <div class="mt-5">

                        <!-- General Info -->
                        <div class="card mb-5 shadow-sm">
                            <div class="card-header bg-light">
                                <h3 class="card-title">General Info</h3>
                            </div>

                            <div class="card-body row">
                                <div class="col-md-6 mb-3">
                                    <strong>Id:</strong>
                                    <span id="tdId"></span>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <strong>Level:</strong>
                                    <span id="tdLevel" class="badge badge-danger"></span>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <strong>Message:</strong>
                                    <span id="tdMessage"></span>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <strong>Timestamp:</strong>
                                    <span id="tdTimestamp"></span>
                                </div>
                            </div>
                        </div>

                        <!-- User Info -->
                        <div class="card mb-5 shadow-sm">
                            <div class="card-header bg-light">
                                <h3 class="card-title">User Info</h3>
                            </div>

                            <div class="card-body row">
                                <div class="col-md-6 mb-3">
                                    <strong>User Name:</strong>
                                    <span id="tdUserName"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Request Info -->
                        <div class="card mb-5 shadow-sm">
                            <div class="card-header bg-light">
                                <h3 class="card-title">Request Info</h3>
                            </div>

                            <div class="card-body row">
                                <div class="col-md-6 mb-3">
                                    <strong>Request Path:</strong>
                                    <span id="tdRequestPath"></span>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <strong>Function Name:</strong>
                                    <span id="tdFunctionName"></span>
                                </div>

                                <div class="col-12 mb-3">
                                    <strong>Parameters:</strong>

                                    <pre class="p-4 bg-light rounded border overflow-auto"
                                         style="max-height:250px;"
                                         id="tdParameters"></pre>
                                </div>
                            </div>
                        </div>

                        <!-- Exception / Stack Trace -->
                        <div class="card mb-5 shadow-sm">
                            <div class="card-header bg-light">
                                <h3 class="card-title">Exception Details</h3>
                            </div>

                            <div class="card-body">

                                <div class="mb-5">
                                    <strong>Exception:</strong>

                                    <pre class="p-4 bg-light rounded border overflow-auto"
                                         style="max-height:300px;"
                                         id="tdException"></pre>
                                </div>

                            </div>
                        </div>

                    </div>

                </form>

            </div>
            <!--end::Modal body-->

        </div>
    </div>
</div>
<!--end::Modal-->
@section Scripts {
    <script src="~/customjs/Admins/exceptions/manage.js" asp-append-version="true"></script>
}